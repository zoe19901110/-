rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEnterpriseMember(enterpriseId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/enterpriseMembers/$(enterpriseId + "_" + request.auth.uid));
    }

    function isEnterpriseAdmin(enterpriseId) {
      return isAuthenticated() && get(/databases/$(database)/documents/enterpriseMembers/$(enterpriseId + "_" + request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Enterprise details
    match /enterprises/{enterpriseId} {
      allow read: if isEnterpriseMember(enterpriseId);
      allow create: if isAuthenticated();
      allow update, delete: if isEnterpriseAdmin(enterpriseId);
    }

    // Enterprise membership mapping
    match /enterpriseMembers/{memberId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isEnterpriseMember(resource.data.enterpriseId));
      allow create: if isAuthenticated();
      allow update, delete: if isEnterpriseAdmin(resource.data.enterpriseId);
    }

    // Personal notes (isolated to the user)
    match /personalNotes/{noteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == (resource == null ? request.resource.data.userId : resource.data.userId);
    }

    // Enterprise projects (isolated to the enterprise)
    match /enterpriseProjects/{projectId} {
      allow read, write: if isEnterpriseMember(resource == null ? request.resource.data.enterpriseId : resource.data.enterpriseId);
    }
  }
}
